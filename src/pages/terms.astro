          var url = new URLSearchParams(location.search);
          var qLang = url.get('lang');
          if (qLang && supported.indexOf(qLang) !== -1) return qLang;

          try {
            var stored = localStorage.getItem('dc_pp_lang');
            if (stored && supported.indexOf(stored) !== -1) return stored;
          } catch (e) {}

          var langs = (navigator.languages && navigator.languages.length)
            ? navigator.languages
            : [navigator.language || 'ko'];
          for (var i = 0; i < langs.length; i++) {
            var l = (langs[i] || '').toLowerCase();
            if (l.indexOf('ko') === 0) return 'ko';
            if (l.indexOf('ja') === 0) return 'ja';
            if (l.indexOf('zh') === 0) {
              if (l.indexOf('hant') !== -1 || l.indexOf('tw') !== -1 ||
                  l.indexOf('hk') !== -1 || l.indexOf('mo') !== -1) return 'zh-TW';
              return 'en';
            }
            if (l.indexOf('en') === 0) return 'en';
          }
          return 'en';
        }

        function applyLang(lang) {
          if (supported.indexOf(lang) === -1) lang = 'ko';
          var articles = document.querySelectorAll('[data-lang-content]');
          for (var i = 0; i < articles.length; i++) {
            articles[i].hidden = articles[i].getAttribute('data-lang-content') !== lang;
          }
          var btns = document.querySelectorAll('[data-lang-btn]');
          for (var j = 0; j < btns.length; j++) {
            if (btns[j].getAttribute('data-lang-btn') === lang) {
              btns[j].classList.add('active');
            } else {
              btns[j].classList.remove('active');
            }
          }
          document.documentElement.lang = (lang === 'zh-TW') ? 'zh-Hant' : lang;
          var titles = {
            'ko': '이용약관 — DreamCat',
            'en': 'Terms of Service — DreamCat',
            'ja': '利用規約 — DreamCat',
            'zh-TW': '服務條款 — DreamCat'
          };
          document.title = titles[lang] || titles.ko;
          try { localStorage.setItem('dc_pp_lang', lang); } catch (e) {}
        }

        applyLang(detectLang());

        var btns = document.querySelectorAll('[data-lang-btn]');
        for (var k = 0; k < btns.length; k++) {
          btns[k].addEventListener('click', function (ev) {
            applyLang(ev.currentTarget.getAttribute('data-lang-btn'));
          });
        }
      })();
    </script>

    <style>
      body {
        font-family: 'Pretendard', sans-serif;
        background: #f5f6f8;
        color: #2b2d2f;
        line-height: 1.7;
      }
      main {
        max-width: 720px;
        margin: 0 auto;
        padding: 40px 20px 80px;
      }
      .back {
        display: inline-block;
        color: #249ce3;
        text-decoration: none;
        margin-bottom: 24px;
        font-weight: 600;
      }
      .lang-switcher {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 28px;
      }
      .lang-switcher button {
        padding: 8px 14px;
        font-family: inherit;
        font-size: 13px;
        font-weight: 600;
        background: #ffffff;
        color: #6b7785;
        border: 1px solid #e5e7eb;
        border-radius: 999px;
        cursor: pointer;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
      }
      .lang-switcher button:hover {
        background: #f5f6f8;
      }
      .lang-switcher button.active {
        background: #249ce3;
        color: #ffffff;
        border-color: #249ce3;
      }
      article[data-lang-content][lang="ja"],
      article[data-lang-content][lang="zh-Hant"] {
        font-family: 'Pretendard', 'Hiragino Sans', 'PingFang TC', sans-serif;
      }
      h1 {
        font-size: 32px;
        margin-bottom: 8px;
      }
      h2 {
        font-size: 18px;
        font-weight: 700;
        margin-top: 32px;
        margin-bottom: 12px;
        color: #1b1a4e;
      }
      .updated {
        color: #6b7785;
        font-size: 14px;
        margin-bottom: 32px;
      }
      p, li {
        font-size: 15px;
        color: #2b2d2f;
      }
      ol, ul {
        padding-left: 24px;
      }
      ul {
        margin-top: 8px;
      }
      a {
        color: #249ce3;
      }
      .contact {
        margin-top: 48px;
        padding: 18px;
        background: #fff;
        border-radius: 12px;
        font-size: 14px;
        color: #6b7785;
        line-height: 1.8;
      }
      .disclaimer {
        margin-top: 16px;
        font-size: 12px;
        color: #9aa3af;
        font-style: italic;
      }
    </style>
  </body>
