    <script is:inline>
      (function () {
        var supported = ['ko', 'en', 'ja', 'zh-TW'];

        function detectLang() {
          // 1) ?lang= 우선
          var url = new URLSearchParams(location.search);
          var qLang = url.get('lang');
          if (qLang && supported.indexOf(qLang) !== -1) return qLang;

          // 2) localStorage 기억 (다음 방문 시 빠르게)
          try {
            var stored = localStorage.getItem('dc_pp_lang');
            if (stored && supported.indexOf(stored) !== -1) return stored;
          } catch (e) {}

          // 3) navigator.language 기반 자동 감지
          var langs = (navigator.languages && navigator.languages.length)
            ? navigator.languages
            : [navigator.language || 'ko'];
          for (var i = 0; i < langs.length; i++) {
            var l = (langs[i] || '').toLowerCase();
            if (l.indexOf('ko') === 0) return 'ko';
            if (l.indexOf('ja') === 0) return 'ja';
            if (l.indexOf('zh') === 0) {
              if (l.indexOf('hant') !== -1 || l.indexOf('tw') !== -1 ||
                  l.indexOf('hk') !== -1 || l.indexOf('mo') !== -1) return 'zh-TW';
              return 'en'; // zh-CN / zh-Hans 는 영어로 폴백
            }
            if (l.indexOf('en') === 0) return 'en';
          }
          return 'en';
        }

        function applyLang(lang) {
          if (supported.indexOf(lang) === -1) lang = 'ko';
          var articles = document.querySelectorAll('[data-lang-content]');
          for (var i = 0; i < articles.length; i++) {
            articles[i].hidden = articles[i].getAttribute('data-lang-content') !== lang;
          }
          var btns = document.querySelectorAll('[data-lang-btn]');
          for (var j = 0; j < btns.length; j++) {
            if (btns[j].getAttribute('data-lang-btn') === lang) {
              btns[j].classList.add('active');
            } else {
              btns[j].classList.remove('active');
            }
          }
          document.documentElement.lang = (lang === 'zh-TW') ? 'zh-Hant' : lang;
          // title 도 locale 별로 갱신 — 검색엔진/공유 미리보기 정확성
          var titles = {
            'ko': '개인정보처리방침 — DreamCat',
            'en': 'Privacy Policy — DreamCat',
            'ja': 'プライバシーポリシー — DreamCat',
            'zh-TW': '隱私權政策 — DreamCat'
          };
          document.title = titles[lang] || titles.ko;
          try { localStorage.setItem('dc_pp_lang', lang); } catch (e) {}
        }

        applyLang(detectLang());

        var btns = document.querySelectorAll('[data-lang-btn]');
        for (var k = 0; k < btns.length; k++) {
          btns[k].addEventListener('click', function (ev) {
            applyLang(ev.currentTarget.getAttribute('data-lang-btn'));
          });
        }
      })();
    </script>

