---
import { I18N } from '../data/i18n.js';

const LANGS = ['ko', 'en', 'ja', 'zh-TW'];
const LANG_LABELS = { ko: '한국어', en: 'English', ja: '日本語', 'zh-TW': '繁體中文' };

const APP_STORE_URL = 'https://apps.apple.com/app/dreamcat'; // TODO: 출시 후 실제 URL 로 갱신
const ICON = '/icon.png';
const LAST_UPDATED = '2026-06-01';
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <title>DreamCat — AI Cat Goal Coach</title>
    <meta id="meta-desc" name="description" content="An AI cat that helps you achieve your dreams." />
    <meta name="theme-color" content="#249CE3" />

    <!-- Open Graph -->
    <meta property="og:title" content="DreamCat — AI Cat Goal Coach" />
    <meta property="og:description" content="Turn big dreams into one doable step for today." />
    <meta property="og:image" content="https://dreamcat.app/og-image.png" />
    <meta property="og:url" content="https://dreamcat.app" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DreamCat" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="DreamCat — AI Cat Goal Coach" />
    <meta name="twitter:description" content="Turn big dreams into one doable step for today." />
    <meta name="twitter:image" content="https://dreamcat.app/og-image.png" />

    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css"
    />
    <link rel="preload" as="fetch" href="/rive/cat.riv" crossorigin="anonymous" type="application/octet-stream" />
  </head>

  <body>
    <!-- ─── Sticky Nav ─────────────────────────────── -->
    <nav class="topnav" aria-label="primary">
      <a class="brand" href="#top" aria-label="DreamCat home">
        <img src={ICON} alt="" width="32" height="32" />
        <span>DreamCat</span>
      </a>
      <ul class="navlinks">
        <li><a href="#how" data-tr="nav.how">작동 방식</a></li>
        <li><a href="#features" data-tr="nav.features">기능</a></li>
        <li><a href="#pricing" data-tr="nav.pricing">가격</a></li>
      </ul>
      <div class="nav-right">
        <div class="lang-pop" data-popup="lang">
          <button class="lang-btn" type="button" aria-haspopup="listbox" aria-expanded="false">
            <span data-active-lang>한국어</span>
            <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <ul class="lang-menu" role="listbox">
            {LANGS.map((l) => (
              <li><button type="button" data-lang-btn={l}>{LANG_LABELS[l]}</button></li>
            ))}
          </ul>
        </div>
        <a class="nav-cta" href={APP_STORE_URL} target="_blank" rel="noopener" data-tr="nav.cta">다운로드</a>
      </div>
    </nav>

    <main id="top">
      <!-- ─── Hero ─────────────────────────────────── -->
      <section class="hero">
        <div class="hero-bg" aria-hidden="true">
          <div class="blob blob1"></div>
          <div class="blob blob2"></div>
          <div class="blob blob3"></div>
          <img src="/icons/cat_star_gold.png" class="floater f1" alt="" />
          <img src="/icons/cat_star_beige.png" class="floater f2" alt="" />
          <img src="/icons/coin.png" class="floater f3" alt="" />
          <img src="/icons/cat_star_gold.png" class="floater f4" alt="" />
          <img src="/icons/paws.png" class="floater f5" alt="" />
        </div>

        <div class="hero-inner">
          <div class="hero-text">
            <span class="eyebrow" data-tr="hero.eyebrow">귀여운 AI 고양이가 함께해요</span>
            <h1>
              <span data-tr="hero.h1Top">꿈을 이루는</span>
              <br />
              <span class="grad" data-tr="hero.h1Highlight">AI 고양이</span>
            </h1>
            <p class="hero-sub" data-tr="hero.sub">큰 꿈을 오늘 할 수 있는 한 걸음으로.<br/>매일 옆에서 응원하는 친구가 함께 자라요.</p>

            <div class="cta-row">
              <a class="appstore-badge" href={APP_STORE_URL} target="_blank" rel="noopener" aria-label="Download on the App Store">
                <svg viewBox="0 0 120 40" width="160" height="48" xmlns="http://www.w3.org/2000/svg">
                  <rect width="120" height="40" rx="8" fill="#000"/>
                  <path d="M27.84 21.07c-.04-3.55 2.9-5.27 3.03-5.36-1.66-2.42-4.23-2.75-5.14-2.78-2.18-.22-4.27 1.28-5.37 1.28-1.12 0-2.83-1.26-4.66-1.22-2.38.03-4.6 1.4-5.84 3.51-2.5 4.33-.64 10.71 1.79 14.22 1.21 1.72 2.65 3.65 4.54 3.58 1.83-.07 2.52-1.18 4.73-1.18 2.19 0 2.84 1.18 4.76 1.13 1.97-.03 3.21-1.74 4.4-3.47 1.4-1.99 1.98-3.93 2.01-4.03-.04-.02-3.85-1.47-3.89-5.84zM24.06 10.5c1.01-1.22 1.69-2.92 1.51-4.6-1.45.06-3.21.97-4.25 2.17-.93 1.06-1.75 2.79-1.53 4.45 1.62.12 3.26-.82 4.27-2.02z" fill="#fff"/>
                  <text x="42" y="17" font-family="system-ui,-apple-system,sans-serif" font-size="9" fill="#fff">Download on the</text>
                  <text x="42" y="32" font-family="system-ui,-apple-system,sans-serif" font-size="17" font-weight="600" fill="#fff">App Store</text>
                </svg>
              </a>
              <a class="cta-link" href="#features" data-tr="hero.ctaSecondary">기능 보기 →</a>
            </div>

            <div class="trust-row">
              <span class="trust"><span class="dot"></span><span data-tr="hero.trust1">9개 언어</span></span>
              <span class="trust"><span class="dot"></span><span data-tr="hero.trust2">AI 코칭</span></span>
              <span class="trust"><span class="dot"></span><span data-tr="hero.trust3">3일 무료 체험</span></span>
            </div>
          </div>

          <div class="hero-cat">
            <div class="cat-stage">
              <canvas id="cat-canvas" width="800" height="800" aria-label="DreamCat animated cat character"></canvas>
              <!-- Rive 로드 실패 시 fallback -->
              <img class="cat-fallback" src="/cat/cat_s5.png" alt="DreamCat character" />
            </div>
            <div class="cat-bubble">
              <span class="cat-bubble-emoji">✨</span>
              <span data-tr="hero.eyebrow">귀여운 AI 고양이가 함께해요</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ─── Pain Point ───────────────────────────── -->
      <section class="section pain reveal" id="pain">
        <span class="eyebrow center" data-tr="pain.eyebrow">의지의 문제가 아닙니다</span>
        <h2 class="center" data-tr="pain.h2">큰 꿈은 첫 걸음이 가장 무겁죠</h2>

        <div class="dream-cards">
          <div class="dream-card" data-tr="pain.dreams.0">"올해는 꼭 원어민처럼 말할 거야"</div>
          <div class="dream-card" data-tr="pain.dreams.1">"바디프로필 촬영에 도전하겠어"</div>
          <div class="dream-card" data-tr="pain.dreams.2">"나만의 브랜드를 만들고 싶어"</div>
        </div>

        <p class="pain-body" data-tr-html="pain.body">작심삼일은 의지가 약해서가 아닙니다.<br/>꿈이 너무 크고 막연해서, 뇌가 어디서부터 시작해야 할지 길을 못 찾는 거예요.</p>
        <p class="pain-highlight" data-tr="pain.highlight">드림캣의 AI 고양이 코치가 당신의 꿈을 오늘 실행 가능한 한 걸음으로 쪼개드립니다.</p>
      </section>

      <!-- ─── 3 Step Mechanism ─────────────────────── -->
      <section class="section steps" id="how">
        <span class="eyebrow center" data-tr="steps.eyebrow">드림캣의 3단계 메커니즘</span>
        <h2 class="center" data-tr="steps.h2">꿈에서 오늘의 한 걸음까지</h2>

        {[0, 1, 2].map((i) => (
          <div class={`step-row reveal ${i % 2 === 1 ? 'reverse' : ''}`}>
            <div class="step-text">
              <span class="step-tag" data-tr={`steps.items.${i}.tag`}>STEP {i + 1}</span>
              <h3 data-tr={`steps.items.${i}.title`}></h3>
              <p data-tr={`steps.items.${i}.body`}></p>
            </div>
            <div class="step-shot">
              <div class="phone-shadow" data-shot-key={['dream', 'home', 'allinone'][i]} data-shot-alt-key={`steps.items.${i}.shotAlt`}>
                <img alt="" />
              </div>
            </div>
          </div>
        ))}
      </section>

      <!-- ─── Features Grid ────────────────────────── -->
      <section class="section features reveal" id="features">
        <span class="eyebrow center" data-tr="features.eyebrow">필요한 건 다 들어있어요</span>
        <h2 class="center" data-tr="features.h2">오늘 하루를 완성하는 도구들</h2>

        <div class="feature-grid">
          {[0,1,2,3,4,5].map((i) => (
            <div class="feature-card">
              <div class="feature-icon">
                <img src="" alt="" data-feature-icon={i} />
              </div>
              <h3 data-tr={`features.items.${i}.title`}></h3>
              <p data-tr={`features.items.${i}.body`}></p>
            </div>
          ))}
        </div>
      </section>

      <!-- ─── Diary AI Spotlight ───────────────────── -->
      <section class="section spotlight reveal">
        <div class="spot-text">
          <span class="eyebrow" data-tr="diaryHighlight.eyebrow">특별히 만든 기능</span>
          <h2 data-tr="diaryHighlight.h2">하루의 끝, 따뜻한 답장이 도착해요</h2>
          <p data-tr="diaryHighlight.body">AI 고양이가 오늘 일기를 읽고 최근 7일의 흐름까지 기억해서 답장해줍니다.</p>
          <ul class="bullets">
            <li><span class="check">✓</span><span data-tr="diaryHighlight.bullet1">사진 첨부로 더 풍부한 기록</span></li>
            <li><span class="check">✓</span><span data-tr="diaryHighlight.bullet2">기분 + 날씨 자동 기록</span></li>
            <li><span class="check">✓</span><span data-tr="diaryHighlight.bullet3">최근 7일 컨텍스트 인식</span></li>
          </ul>
        </div>
        <div class="spot-shot">
          <div class="phone-shadow" data-shot-key="diary" data-shot-alt="Diary">
            <img alt="" />
          </div>
        </div>
      </section>

      <!-- ─── Companion (with bg) ──────────────────── -->
      <section class="section companion reveal">
        <div class="companion-bg" style="background-image:url('/bg/bg_cat_room.png')"></div>
        <div class="companion-overlay"></div>
        <div class="companion-inner">
          <div class="companion-text">
            <span class="eyebrow light" data-tr="companion.eyebrow">곁에 작은 친구가 있어요</span>
            <h2 data-tr="companion.h2">함께 자라는 고양이 친구</h2>
            <p data-tr="companion.body">귀여운 AI 고양이가 매일 다른 표정으로 인사합니다.</p>
            <div class="chip-row">
              <span class="chip" data-tr="companion.tag1">옷장 커스터마이징</span>
              <span class="chip" data-tr="companion.tag2">방 꾸미기</span>
              <span class="chip" data-tr="companion.tag3">매일 다른 표정</span>
            </div>
          </div>
          <div class="companion-shot">
            <div class="phone-shadow" data-shot-key="customize" data-shot-alt="Customize">
              <img alt="" />
            </div>
          </div>
        </div>
      </section>

      <!-- ─── iPad Section ─────────────────────────── -->
      <section class="section ipad reveal">
        <div class="ipad-text">
          <span class="eyebrow" data-tr="ipad.eyebrow">어디서든 같은 경험</span>
          <h2 data-tr="ipad.h2">iPad 에서도 완벽하게</h2>
          <p data-tr="ipad.body">아이폰에서 시작한 꿈을 더 큰 화면으로 이어가세요.</p>
        </div>
        <div class="ipad-shots">
          <div class="ipad-frame" data-shot-key="ipad_home"><img alt="iPad home" /></div>
          <div class="ipad-frame ipad-back" data-shot-key="ipad_dream"><img alt="iPad dream" /></div>
        </div>
      </section>

      <!-- ─── Pricing ──────────────────────────────── -->
      <section class="section pricing reveal" id="pricing">
        <span class="eyebrow center" data-tr="pricing.eyebrow">내 페이스대로</span>
        <h2 class="center" data-tr="pricing.h2">무료로도 충분해요</h2>

        <div class="pricing-grid">
          <div class="price-card">
            <div class="price-head">
              <span class="price-name" data-tr="pricing.free.name">무료</span>
              <div class="price-line">
                <span class="price-num" data-tr="pricing.free.price">₩0</span>
                <span class="price-period" data-tr="pricing.free.period">영원히</span>
              </div>
            </div>
            <ul class="price-items">
              {[0,1,2,3,4].map((i) => (
                <li><span class="check">✓</span><span data-tr={`pricing.free.items.${i}`}></span></li>
              ))}
            </ul>
            <a class="price-cta secondary" href={APP_STORE_URL} target="_blank" rel="noopener" data-tr="pricing.free.cta">무료로 시작</a>
          </div>

          <div class="price-card pro">
            <span class="pro-badge" data-tr="pricing.pro.badge">인기</span>
            <div class="price-head">
              <span class="price-name" data-tr="pricing.pro.name">프로</span>
              <div class="price-line">
                <span class="price-num" data-tr="pricing.pro.price">₩3,900</span>
                <span class="price-period" data-tr="pricing.pro.period">/월</span>
              </div>
              <span class="price-note" data-tr="pricing.pro.priceNote">3일 무료 체험</span>
            </div>
            <ul class="price-items">
              {[0,1,2,3,4].map((i) => (
                <li><span class="check gold">✓</span><span data-tr={`pricing.pro.items.${i}`}></span></li>
              ))}
            </ul>
            <a class="price-cta primary" href={APP_STORE_URL} target="_blank" rel="noopener" data-tr="pricing.pro.cta">3일 무료 체험</a>
            <p class="price-foot" data-tr="pricing.pro.annual">연 ₩29,000 / 평생 ₩59,000</p>
          </div>
        </div>
      </section>

      <!-- ─── Languages ────────────────────────────── -->
      <section class="section langs reveal">
        <span class="eyebrow center" data-tr="languages.eyebrow">글로벌</span>
        <h2 class="center" data-tr="languages.h2">9개 언어 지원</h2>
        <p class="center langs-body" data-tr="languages.body">내 모국어로, 가장 익숙한 방식으로 꿈을 이루세요.</p>
        <p class="lang-list" data-tr="languages.list"></p>
      </section>

      <!-- ─── Final CTA ────────────────────────────── -->
      <section class="section final-cta reveal">
        <div class="final-bg" aria-hidden="true">
          <img src="/icons/cat_star_gold.png" class="floater f1" alt="" />
          <img src="/icons/cat_star_beige.png" class="floater f2" alt="" />
          <img src="/icons/paws.png" class="floater f3" alt="" />
        </div>
        <div class="final-inner">
          <img src="/cat/cat_icon.png" class="final-cat" alt="DreamCat" />
          <h2 data-tr="finalCta.h2">오늘부터, 내 인생이 달라집니다</h2>
          <p data-tr="finalCta.sub">AI 고양이 코치와 함께 첫 걸음을 내딛으세요.</p>
          <a class="appstore-badge big" href={APP_STORE_URL} target="_blank" rel="noopener">
            <svg viewBox="0 0 120 40" width="200" height="60"><rect width="120" height="40" rx="8" fill="#000"/><path d="M27.84 21.07c-.04-3.55 2.9-5.27 3.03-5.36-1.66-2.42-4.23-2.75-5.14-2.78-2.18-.22-4.27 1.28-5.37 1.28-1.12 0-2.83-1.26-4.66-1.22-2.38.03-4.6 1.4-5.84 3.51-2.5 4.33-.64 10.71 1.79 14.22 1.21 1.72 2.65 3.65 4.54 3.58 1.83-.07 2.52-1.18 4.73-1.18 2.19 0 2.84 1.18 4.76 1.13 1.97-.03 3.21-1.74 4.4-3.47 1.4-1.99 1.98-3.93 2.01-4.03-.04-.02-3.85-1.47-3.89-5.84zM24.06 10.5c1.01-1.22 1.69-2.92 1.51-4.6-1.45.06-3.21.97-4.25 2.17-.93 1.06-1.75 2.79-1.53 4.45 1.62.12 3.26-.82 4.27-2.02z" fill="#fff"/><text x="42" y="17" font-family="system-ui,sans-serif" font-size="9" fill="#fff">Download on the</text><text x="42" y="32" font-family="system-ui,sans-serif" font-size="17" font-weight="600" fill="#fff">App Store</text></svg>
          </a>
        </div>
      </section>

      <!-- ─── Footer ───────────────────────────────── -->
      <footer>
        <div class="footer-inner">
          <div class="footer-brand">
            <img src={ICON} alt="DreamCat" />
            <div>
              <strong>DreamCat</strong>
              <span class="footer-tag" data-tr="footer.tagline">꿈을 이루는 AI 고양이</span>
            </div>
          </div>
          <nav class="footer-nav">
            <a href="/privacy" data-tr="footer.privacy">개인정보 처리방침</a>
            <a href="/terms" data-tr="footer.terms">이용약관</a>
            <a href="mailto:hello@dreamcat.app" data-tr="footer.contact">문의</a>
          </nav>
          <p class="footer-copy" data-tr="footer.copy">© 2026 UZUPLAY. All rights reserved.</p>
        </div>
      </footer>
    </main>

    <!-- ─── i18n data inlined ──────────────────────── -->
    <script id="i18n-data" type="application/json" set:html={JSON.stringify(I18N)}></script>

    <!-- ─── Boot script ────────────────────────────── -->
    <script type="module">
      // ───────── i18n (privacy/terms 와 동일 디텍션 + 언어 토글) ─────────
      const I18N = JSON.parse(document.getElementById('i18n-data').textContent);
      const SUPPORTED = ['ko', 'en', 'ja', 'zh-TW'];

      function detectLang() {
        const url = new URLSearchParams(location.search);
        const q = url.get('lang');
        if (q && SUPPORTED.includes(q)) return q;
        try {
          const stored = localStorage.getItem('dc_lang');
          if (stored && SUPPORTED.includes(stored)) return stored;
        } catch (e) {}
        const langs = (navigator.languages && navigator.languages.length) ? navigator.languages : [navigator.language || 'en'];
        for (const raw of langs) {
          const l = (raw || '').toLowerCase();
          if (l.startsWith('ko')) return 'ko';
          if (l.startsWith('ja')) return 'ja';
          if (l.startsWith('zh')) {
            if (l.includes('hant') || l.includes('tw') || l.includes('hk') || l.includes('mo')) return 'zh-TW';
          }
          if (l.startsWith('en')) return 'en';
        }
        return 'en';
      }

      function getDeep(obj, path) {
        return path.split('.').reduce((a, k) => (a == null ? undefined : a[k]), obj);
      }

      function applyLang(lang) {
        if (!SUPPORTED.includes(lang)) lang = 'ko';
        const D = I18N[lang];
        if (!D) return;

        // html lang + title + meta
        document.documentElement.lang = D.htmlLang;
        document.title = D.title;
        const meta = document.getElementById('meta-desc');
        if (meta) meta.setAttribute('content', D.metaDesc);

        // 모든 data-tr 노드 텍스트 교체
        document.querySelectorAll('[data-tr]').forEach((el) => {
          const v = getDeep(D, el.getAttribute('data-tr'));
          if (typeof v === 'string') el.textContent = v;
        });
        // 줄바꿈 포함된 본문은 별도 처리 (data-tr-html)
        document.querySelectorAll('[data-tr-html]').forEach((el) => {
          const v = getDeep(D, el.getAttribute('data-tr-html'));
          if (typeof v === 'string') el.innerHTML = v.replace(/\n/g, '<br/>');
        });

        // hero.sub 는 줄바꿈 살리기
        const heroSub = document.querySelector('[data-tr="hero.sub"]');
        if (heroSub && D.hero?.sub) heroSub.innerHTML = D.hero.sub.replace(/\n/g, '<br/>');

        // 활성 언어 라벨
        document.querySelectorAll('[data-active-lang]').forEach((el) => { el.textContent = ({ ko:'한국어', en:'English', ja:'日本語', 'zh-TW':'繁體中文' }[lang]); });

        // 스크린샷 src — 언어별 폴더
        document.querySelectorAll('[data-shot-key]').forEach((el) => {
          const key = el.getAttribute('data-shot-key');
          const img = el.querySelector('img');
          if (img) {
            img.src = `/screenshots/${lang}/${key}.jpg`;
            const altKey = el.getAttribute('data-shot-alt-key');
            if (altKey) {
              const alt = getDeep(D, altKey);
              if (alt) img.alt = alt;
            }
          }
        });

        // 기능 아이콘 src
        const iconList = ['btn_diary','btn_alarm','btn_timer','btn_sleep','btn_breath','btn_memo'];
        document.querySelectorAll('[data-feature-icon]').forEach((el) => {
          const i = parseInt(el.getAttribute('data-feature-icon'), 10);
          const iconName = D.features?.items?.[i]?.icon || iconList[i];
          el.src = `/icons/${iconName}.png`;
          el.alt = D.features?.items?.[i]?.title || '';
        });

        // 언어 메뉴 active 표시
        document.querySelectorAll('[data-lang-btn]').forEach((btn) => {
          btn.classList.toggle('active', btn.getAttribute('data-lang-btn') === lang);
        });

        try { localStorage.setItem('dc_lang', lang); } catch (e) {}
      }

      applyLang(detectLang());

      // 언어 메뉴
      const langPop = document.querySelector('[data-popup="lang"]');
      const langBtn = langPop?.querySelector('.lang-btn');
      langBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        langPop.classList.toggle('open');
        const ex = langPop.classList.contains('open');
        langBtn.setAttribute('aria-expanded', String(ex));
      });
      document.addEventListener('click', () => langPop?.classList.remove('open'));
      document.querySelectorAll('[data-lang-btn]').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          applyLang(btn.getAttribute('data-lang-btn'));
          langPop?.classList.remove('open');
        });
      });

      // ───────── Scroll reveal ─────────
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('in');
              io.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -80px 0px' });
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      } else {
        document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in'));
      }

      // ───────── Sticky nav scroll state ─────────
      const nav = document.querySelector('.topnav');
      const onScroll = () => {
        if (window.scrollY > 24) nav?.classList.add('scrolled');
        else nav?.classList.remove('scrolled');
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });

      // ───────── Rive (cat.riv) — lazy load ─────────
      let riveLoaded = false;
      async function loadRive() {
        if (riveLoaded) return;
        riveLoaded = true;
        try {
          const mod = await import('https://cdn.jsdelivr.net/npm/@rive-app/canvas@2/+esm');
          const canvas = document.getElementById('cat-canvas');
          if (!canvas) return;
          const r = new mod.Rive({
            src: '/rive/cat.riv',
            canvas,
            autoplay: true,
            // State machine 이름 추정 — cat.riv 의 첫 SM 자동 사용 시도
            stateMachines: 'State Machine 1',
            onLoad: () => {
              try { r.resizeDrawingSurfaceToCanvas(); } catch (e) {}
              canvas.classList.add('loaded');
            },
            onLoadError: () => {
              // SM 매칭 실패 시 단순 artboard 로 재시도
              try {
                const r2 = new mod.Rive({
                  src: '/rive/cat.riv',
                  canvas,
                  autoplay: true,
                  onLoad: () => {
                    try { r2.resizeDrawingSurfaceToCanvas(); } catch (e) {}
                    canvas.classList.add('loaded');
                  },
                });
              } catch (e) {}
            },
          });
        } catch (e) {
          // CDN 차단 등 — fallback img 그대로 노출
        }
      }
      // hero 진입 시 로드
      const heroCat = document.querySelector('.hero-cat');
      if (heroCat && 'IntersectionObserver' in window) {
        const ho = new IntersectionObserver((entries) => {
          if (entries.some((e) => e.isIntersecting)) {
            loadRive();
            ho.disconnect();
          }
        }, { threshold: 0.05 });
        ho.observe(heroCat);
      } else {
        loadRive();
      }
    </script>

