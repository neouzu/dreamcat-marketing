---
import { I18N } from '../data/i18n.js';

const LANGS = ['ko', 'en', 'ja', 'zh-TW'];
const LANG_LABELS = { ko: '한국어', en: 'English', ja: '日本語', 'zh-TW': '繁體中文' };

const APP_STORE_URL = 'https://apps.apple.com/app/dreamcat'; // TODO: 출시 후 실제 URL 로 갱신
const ICON = '/icon.png';
const LAST_UPDATED = '2026-06-01';
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <title>DreamCat — AI Cat Goal Coach</title>
    <meta id="meta-desc" name="description" content="An AI cat that helps you achieve your dreams." />
    <meta name="theme-color" content="#249CE3" />

    <!-- Open Graph -->
    <meta property="og:title" content="DreamCat — AI Cat Goal Coach" />
    <meta property="og:description" content="Turn big dreams into one doable step for today." />
    <meta property="og:image" content="https://dreamcat.app/og-image.png" />
    <meta property="og:url" content="https://dreamcat.app" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DreamCat" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="DreamCat — AI Cat Goal Coach" />
    <meta name="twitter:description" content="Turn big dreams into one doable step for today." />
    <meta name="twitter:image" content="https://dreamcat.app/og-image.png" />

    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css"
    />
    <!-- cat.riv 는 hero 진입 시 lazy-load — preload 안 함 (위 콘솔 경고 회피) -->
  </head>

  <body>
    <!-- ─── Sticky Nav ─────────────────────────────── -->
    <nav class="topnav" aria-label="primary">
      <a class="brand" href="#top" aria-label="DreamCat home">
        <img src={ICON} alt="" width="32" height="32" />
        <span>DreamCat</span>
      </a>
      <ul class="navlinks">
        <li><a href="#how" data-tr="nav.how">이야기</a></li>
        <li><a href="#features" data-tr="nav.features">둘러보기</a></li>
      </ul>
      <div class="nav-right">
        <div class="lang-pop" data-popup="lang">
          <button class="lang-btn" type="button" aria-haspopup="listbox" aria-expanded="false">
            <span data-active-lang>한국어</span>
            <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <ul class="lang-menu" role="listbox">
            {LANGS.map((l) => (
              <li><button type="button" data-lang-btn={l}>{LANG_LABELS[l]}</button></li>
            ))}
          </ul>
        </div>
        <a class="nav-cta" href={APP_STORE_URL} target="_blank" rel="noopener" data-tr="nav.cta">다운로드</a>
      </div>
    </nav>

    <main id="top">
      <!-- ─── Hero — 좌우 split, 한 viewport 안에 완결 ─── -->
      <section class="hero">
        <div class="hero-bg" aria-hidden="true">
          <!-- 랜덤 roomskin/garden — 두 레이어 cross-fade 로 부드럽게 교체 -->
          <div class="hero-bg-image" data-bg-layer="a"></div>
          <div class="hero-bg-image" data-bg-layer="b"></div>
          <img src="/icons/cat_star_gold.png" class="hero-deco d1" alt="" />
          <img src="/icons/paws.png" class="hero-deco d2" alt="" />
          <img src="/icons/coin.png" class="hero-deco d3" alt="" />
          <img src="/icons/cat_star_beige.png" class="hero-deco d4" alt="" />
          <img src="/icons/cat_star_gold.png" class="hero-deco d5" alt="" />
          <img src="/icons/coin.png" class="hero-deco d6" alt="" />
          <img src="/icons/paws.png" class="hero-deco d7" alt="" />
        </div>

        <div class="hero-grid">
          <div class="hero-text">
            <h1 class="hero-headline">
              <span class="hl-line" data-tr="hero.h1Top">꿈을 이루어 주는 고양이와</span>
              <span class="hl-line accent" data-tr="hero.h1Highlight">함께하는 나의 하루</span>
            </h1>
            <p class="hero-sub" data-tr="hero.sub">큰 꿈을 오늘의 작은 한 걸음으로.<br/>매일 옆에서 응원하는 작은 친구.</p>

            <div class="hero-cta">
              <a class="store-btn store-ios" href={APP_STORE_URL} target="_blank" rel="noopener" aria-label="Download on the App Store">
                <svg class="store-icon" viewBox="0 0 24 28" width="22" height="26" aria-hidden="true">
                  <path fill="currentColor" d="M19.36 14.86c-.04-3.78 3.08-5.6 3.22-5.69-1.76-2.57-4.5-2.93-5.46-2.96-2.32-.24-4.54 1.37-5.71 1.37-1.19 0-3.01-1.34-4.95-1.3-2.54.04-4.9 1.48-6.21 3.74-2.66 4.62-.68 11.4 1.91 15.13 1.29 1.83 2.82 3.88 4.83 3.81 1.94-.08 2.67-1.25 5.02-1.25 2.34 0 3.01 1.25 5.07 1.21 2.1-.04 3.42-1.86 4.69-3.7 1.49-2.12 2.1-4.18 2.14-4.29-.05-.02-4.1-1.57-4.14-6.23zM15.6 3.65c1.07-1.3 1.8-3.11 1.6-4.9-1.55.06-3.42 1.03-4.52 2.3-.99 1.13-1.86 2.97-1.63 4.74 1.73.13 3.47-.88 4.55-2.14z"/>
                </svg>
                <span class="store-text">
                  <span class="store-eyebrow">Download on the</span>
                  <span class="store-name" data-tr="hero.ctaPrimary">App Store</span>
                </span>
              </a>
              <span class="store-btn store-android coming" aria-label="Coming soon to Google Play">
                <svg class="store-icon" viewBox="0 0 24 26" width="22" height="24" aria-hidden="true">
                  <path fill="currentColor" d="M3.61.97A1.99 1.99 0 0 0 2.5 2.75v20.5c0 .72.39 1.35.97 1.69L15.25 13 3.61.97zm12.7 11.27 3.1-3.04L5.97 1.55a2 2 0 0 0-1.5-.18l11.84 10.87zm5.36-1.13-3.74 2.15 3.7 3.62c1.08-.55 1.78-1.6 1.78-2.92 0-1.31-.69-2.36-1.74-2.85zM5.97 24.45a2 2 0 0 0 1.43-.13l14.27-8.13-3.1-3.04-12.6 11.3z"/>
                </svg>
                <span class="store-text">
                  <span class="store-eyebrow" data-tr="hero.ctaSecondaryEyebrow">곧 출시</span>
                  <span class="store-name" data-tr="hero.ctaSecondary">Google Play</span>
                </span>
              </span>
            </div>

          </div>

          <div class="hero-cat-stage">
            <div class="cat-pedestal" aria-hidden="true"></div>
            <canvas id="cat-canvas" width="900" height="900" aria-label="DreamCat animated cat character"></canvas>
            <img class="cat-fallback" src="/cat/cat_s5.png" alt="DreamCat character" />
          </div>
        </div>
      </section>

      <!-- ─── Pain Point ───────────────────────────── -->
      <section class="section pain reveal" id="pain">
        <span class="eyebrow center" data-tr="pain.eyebrow">의지의 문제가 아닙니다</span>
        <h2 class="center" data-tr="pain.h2">큰 꿈은 첫 걸음이 가장 무겁죠</h2>

        <div class="dream-cards">
          <div class="dream-card" data-tr="pain.dreams.0">"올해는 꼭 원어민처럼 말할 거야"</div>
          <div class="dream-card" data-tr="pain.dreams.1">"바디프로필 촬영에 도전하겠어"</div>
          <div class="dream-card" data-tr="pain.dreams.2">"나만의 브랜드를 만들고 싶어"</div>
        </div>

        <p class="pain-body" data-tr-html="pain.body">작심삼일은 의지가 약해서가 아닙니다.<br/>꿈이 너무 크고 막연해서, 뇌가 어디서부터 시작해야 할지 길을 못 찾는 거예요.</p>
        <p class="pain-highlight" data-tr="pain.highlight">드림캣의 AI 고양이 코치가 당신의 꿈을 오늘 실행 가능한 한 걸음으로 쪼개드립니다.</p>
      </section>

      <!-- ─── 3 Step Mechanism ─────────────────────── -->
      <section class="section steps" id="how">
        <span class="eyebrow center" data-tr="steps.eyebrow">드림캣의 3단계 메커니즘</span>
        <h2 class="center" data-tr="steps.h2">꿈에서 오늘의 한 걸음까지</h2>

        {[0, 1, 2].map((i) => (
          <div class={`step-row reveal ${i % 2 === 1 ? 'reverse' : ''}`}>
            <div class="step-text">
              <span class="step-tag" data-tr={`steps.items.${i}.tag`}>STEP {i + 1}</span>
              <h3 data-tr={`steps.items.${i}.title`}></h3>
              <p data-tr={`steps.items.${i}.body`}></p>
            </div>
            <div class="step-shot">
              <div class="phone-shadow" data-shot-key={['dream', 'home', 'allinone'][i]} data-shot-alt-key={`steps.items.${i}.shotAlt`}>
                <img alt="" />
              </div>
            </div>
          </div>
        ))}
      </section>

      <!-- ─── Features Grid ────────────────────────── -->
      <section class="section features reveal" id="features">
        <span class="eyebrow center" data-tr="features.eyebrow">필요한 건 다 들어있어요</span>
        <h2 class="center" data-tr="features.h2">오늘 하루를 완성하는 도구들</h2>

        <div class="feature-grid">
          {[0,1,2,3,4,5].map((i) => (
            <div class="feature-card">
              <div class="feature-icon">
                <img src="" alt="" data-feature-icon={i} />
              </div>
              <h3 data-tr={`features.items.${i}.title`}></h3>
              <p data-tr={`features.items.${i}.body`}></p>
            </div>
          ))}
        </div>
      </section>

      <!-- ─── Diary AI Spotlight ───────────────────── -->
      <section class="section spotlight reveal">
        <div class="spot-text">
          <span class="eyebrow" data-tr="diaryHighlight.eyebrow">특별히 만든 기능</span>
          <h2 data-tr="diaryHighlight.h2">하루의 끝, 따뜻한 답장이 도착해요</h2>
          <p data-tr="diaryHighlight.body">AI 고양이가 오늘 일기를 읽고 최근 7일의 흐름까지 기억해서 답장해줍니다.</p>
          <ul class="bullets">
            <li><span class="check">✓</span><span data-tr="diaryHighlight.bullet1">사진 첨부로 더 풍부한 기록</span></li>
            <li><span class="check">✓</span><span data-tr="diaryHighlight.bullet2">기분 + 날씨 자동 기록</span></li>
            <li><span class="check">✓</span><span data-tr="diaryHighlight.bullet3">최근 7일 컨텍스트 인식</span></li>
          </ul>
        </div>
        <div class="spot-shot">
          <div class="phone-shadow" data-shot-key="diary" data-shot-alt="Diary">
            <img alt="" />
          </div>
        </div>
      </section>

      <!-- ─── Companion (with bg) ──────────────────── -->
      <section class="section companion reveal">
        <div class="companion-bg" style="background-image:url('/bg/bg_cat_room.png')"></div>
        <div class="companion-overlay"></div>
        <div class="companion-inner">
          <div class="companion-text">
            <span class="eyebrow light" data-tr="companion.eyebrow">곁에 작은 친구가 있어요</span>
            <h2 data-tr="companion.h2">함께 자라는 고양이 친구</h2>
            <p data-tr="companion.body">귀여운 AI 고양이가 매일 다른 표정으로 인사합니다.</p>
            <div class="chip-row">
              <span class="chip" data-tr="companion.tag1">옷장 커스터마이징</span>
              <span class="chip" data-tr="companion.tag2">방 꾸미기</span>
              <span class="chip" data-tr="companion.tag3">매일 다른 표정</span>
            </div>
          </div>
          <div class="companion-shot">
            <div class="phone-shadow" data-shot-key="customize" data-shot-alt="Customize">
              <img alt="" />
            </div>
          </div>
        </div>
      </section>

      <!-- ─── iPad Section ─────────────────────────── -->
      <section class="section ipad reveal">
        <div class="ipad-text">
          <span class="eyebrow" data-tr="ipad.eyebrow">어디서든 같은 경험</span>
          <h2 data-tr="ipad.h2">iPad 에서도 완벽하게</h2>
          <p data-tr="ipad.body">아이폰에서 시작한 꿈을 더 큰 화면으로 이어가세요.</p>
        </div>
        <div class="ipad-shots">
          <div class="ipad-frame" data-shot-key="ipad_home"><img alt="iPad home" /></div>
          <div class="ipad-frame ipad-back" data-shot-key="ipad_dream"><img alt="iPad dream" /></div>
        </div>
      </section>

      <!-- ─── Languages ────────────────────────────── -->
      <section class="section langs reveal">
        <span class="eyebrow center" data-tr="languages.eyebrow">글로벌</span>
        <h2 class="center" data-tr="languages.h2">9개 언어 지원</h2>
        <p class="center langs-body" data-tr="languages.body">내 모국어로, 가장 익숙한 방식으로 꿈을 이루세요.</p>
        <p class="lang-list" data-tr="languages.list"></p>
      </section>

      <!-- ─── Final CTA ────────────────────────────── -->
      <section class="section final-cta reveal">
        <div class="final-bg" aria-hidden="true">
          <img src="/icons/cat_star_gold.png" class="floater f1" alt="" />
          <img src="/icons/cat_star_beige.png" class="floater f2" alt="" />
          <img src="/icons/paws.png" class="floater f3" alt="" />
        </div>
        <div class="final-inner">
          <img src="/cat/cat_icon.png" class="final-cat" alt="DreamCat" />
          <h2 data-tr="finalCta.h2">오늘부터, 내 인생이 달라집니다</h2>
          <p data-tr="finalCta.sub">AI 고양이 코치와 함께 첫 걸음을 내딛으세요.</p>
          <div class="hero-cta final">
            <a class="store-btn store-ios" href={APP_STORE_URL} target="_blank" rel="noopener" aria-label="Download on the App Store">
              <svg class="store-icon" viewBox="0 0 24 28" width="24" height="28" aria-hidden="true">
                <path fill="currentColor" d="M19.36 14.86c-.04-3.78 3.08-5.6 3.22-5.69-1.76-2.57-4.5-2.93-5.46-2.96-2.32-.24-4.54 1.37-5.71 1.37-1.19 0-3.01-1.34-4.95-1.3-2.54.04-4.9 1.48-6.21 3.74-2.66 4.62-.68 11.4 1.91 15.13 1.29 1.83 2.82 3.88 4.83 3.81 1.94-.08 2.67-1.25 5.02-1.25 2.34 0 3.01 1.25 5.07 1.21 2.1-.04 3.42-1.86 4.69-3.7 1.49-2.12 2.1-4.18 2.14-4.29-.05-.02-4.1-1.57-4.14-6.23zM15.6 3.65c1.07-1.3 1.8-3.11 1.6-4.9-1.55.06-3.42 1.03-4.52 2.3-.99 1.13-1.86 2.97-1.63 4.74 1.73.13 3.47-.88 4.55-2.14z"/>
              </svg>
              <span class="store-text">
                <span class="store-eyebrow">Download on the</span>
                <span class="store-name" data-tr="hero.ctaPrimary">App Store</span>
              </span>
            </a>
            <span class="store-btn store-android coming" aria-label="Coming soon to Google Play">
              <svg class="store-icon" viewBox="0 0 24 26" width="24" height="26" aria-hidden="true">
                <path fill="currentColor" d="M3.61.97A1.99 1.99 0 0 0 2.5 2.75v20.5c0 .72.39 1.35.97 1.69L15.25 13 3.61.97zm12.7 11.27 3.1-3.04L5.97 1.55a2 2 0 0 0-1.5-.18l11.84 10.87zm5.36-1.13-3.74 2.15 3.7 3.62c1.08-.55 1.78-1.6 1.78-2.92 0-1.31-.69-2.36-1.74-2.85zM5.97 24.45a2 2 0 0 0 1.43-.13l14.27-8.13-3.1-3.04-12.6 11.3z"/>
              </svg>
              <span class="store-text">
                <span class="store-eyebrow" data-tr="hero.ctaSecondaryEyebrow">곧 출시</span>
                <span class="store-name" data-tr="hero.ctaSecondary">Google Play</span>
              </span>
            </span>
          </div>
        </div>
      </section>

      <!-- ─── Footer ───────────────────────────────── -->
      <footer>
        <div class="footer-inner">
          <div class="footer-brand">
            <img src={ICON} alt="DreamCat" />
            <div>
              <strong>DreamCat</strong>
              <span class="footer-tag" data-tr="footer.tagline">꿈을 이루는 AI 고양이</span>
            </div>
          </div>
          <nav class="footer-nav">
            <a href="/privacy" data-tr="footer.privacy">개인정보 처리방침</a>
            <a href="/terms" data-tr="footer.terms">이용약관</a>
            <a href="mailto:hello@dreamcat.app" data-tr="footer.contact">문의</a>
          </nav>
          <p class="footer-copy" data-tr="footer.copy">© 2026 UZUPLAY. All rights reserved.</p>
        </div>
      </footer>
    </main>

    <!-- ─── i18n data inlined ──────────────────────── -->
    <script id="i18n-data" type="application/json" set:html={JSON.stringify(I18N)}></script>

    <!-- ─── Boot script ────────────────────────────── -->
    <!-- ─── Boot script (Astro 가 chunk 로 번들) ─── -->
    <script>
      import "../scripts/landing.js";
    </script>

    <!-- ─── Styles ─────────────────────────────────── -->
    <style is:global>
      :root {
        --primary: #249ce3;
        --primary-soft: #c7e8fa;
        --primary-deep: #1880c3;
        --cream: #fff8e5;
        --gold: #f5b100;
        --gold-soft: #ffe9a8;
        --green: #4caf50;
        --bg: #f8fafc;
        --bg-soft: #eef7fe;
        --card: #ffffff;
        --text: #1b1d20;
        --text-soft: #5b6470;
        --text-mute: #9aa3af;
        --border: #e8eaed;
        --radius-lg: 28px;
        --radius-md: 20px;
        --radius-sm: 12px;
        --shadow-card: 0 10px 40px -10px rgba(36, 156, 227, 0.18);
        --shadow-phone: 0 30px 80px -20px rgba(36, 80, 130, 0.35);
        --shadow-soft: 0 4px 18px rgba(36, 80, 130, 0.08);
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      a { color: inherit; text-decoration: none; }
      img { max-width: 100%; display: block; }
      h1, h2, h3 { font-weight: 800; line-height: 1.2; letter-spacing: -0.02em; }

      .eyebrow {
        display: inline-block;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.08em;
        color: var(--primary);
        text-transform: uppercase;
        background: var(--bg-soft);
        padding: 6px 14px;
        border-radius: 999px;
        margin-bottom: 18px;
      }
      .eyebrow.center { display: block; width: fit-content; margin-left: auto; margin-right: auto; }
      .eyebrow.light {
        color: #fff;
        background: rgba(255,255,255,0.18);
        backdrop-filter: blur(8px);
      }
      .center { text-align: center; }

      /* ─── Sticky Nav ─── */
      .topnav {
        position: sticky;
        top: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 12px max(20px, 6vw);
        background: rgba(255, 255, 255, 0.72);
        backdrop-filter: saturate(180%) blur(20px);
        -webkit-backdrop-filter: saturate(180%) blur(20px);
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s, background 0.2s;
      }
      .topnav.scrolled {
        border-bottom-color: var(--border);
        background: rgba(255, 255, 255, 0.92);
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 800;
        font-size: 17px;
        letter-spacing: -0.02em;
      }
      .brand img { width: 32px; height: 32px; border-radius: 8px; }
      .navlinks {
        display: flex;
        gap: 24px;
        list-style: none;
        flex: 1;
        justify-content: center;
        font-size: 14px;
        font-weight: 600;
      }
      .navlinks a {
        color: var(--text-soft);
        transition: color 0.15s;
      }
      .navlinks a:hover { color: var(--primary); }
      .nav-right { display: flex; gap: 10px; align-items: center; }
      .nav-cta {
        padding: 9px 16px;
        background: var(--primary);
        color: #fff !important;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 700;
        transition: transform 0.15s, box-shadow 0.15s;
      }
      .nav-cta:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 18px rgba(36, 156, 227, 0.32);
      }

      .lang-pop { position: relative; }
      .lang-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 9px 12px;
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 10px;
        font: 600 13px Pretendard, sans-serif;
        color: var(--text);
        cursor: pointer;
        transition: background 0.15s;
      }
      .lang-btn:hover { background: var(--bg-soft); }
      .lang-menu {
        position: absolute;
        top: calc(100% + 6px);
        right: 0;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        list-style: none;
        padding: 6px;
        min-width: 140px;
        box-shadow: var(--shadow-card);
        opacity: 0;
        pointer-events: none;
        transform: translateY(-4px);
        transition: all 0.15s;
      }
      .lang-pop.open .lang-menu {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
      }
      .lang-menu button {
        width: 100%;
        text-align: left;
        background: transparent;
        border: 0;
        padding: 8px 12px;
        font: 500 13px Pretendard, sans-serif;
        color: var(--text);
        border-radius: 8px;
        cursor: pointer;
      }
      .lang-menu button:hover { background: var(--bg-soft); }
      .lang-menu button.active {
        background: var(--primary);
        color: #fff;
        font-weight: 700;
      }

      @media (max-width: 720px) {
        .navlinks { display: none; }
      }

      /* ─── Hero — 좌우 split + 컴팩트 고정 높이 + 진한 sky blue + 랜덤 배경 ─── */
      .hero {
        position: relative;
        height: 540px;
        display: flex;
        align-items: center;
        padding: 0 max(20px, 5vw);
        overflow: hidden;
        background: linear-gradient(180deg, #1f8fc8 0%, #2ba0d8 50%, #3ab1e3 100%);
      }
      /* 랜덤 배경 이미지 — 두 레이어 cross-fade */
      .hero-bg-image {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        opacity: 0;
        mix-blend-mode: luminosity;
        transition: opacity 1.2s ease;
        will-change: opacity;
      }
      .hero-bg-image.active {
        opacity: 0.18;
      }
      /* 가독성 향상용 부드러운 오버레이 */
      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
          radial-gradient(ellipse 60% 70% at 25% 50%, rgba(20, 110, 165, 0.4) 0%, transparent 65%),
          radial-gradient(ellipse 50% 60% at 78% 50%, rgba(255, 255, 255, 0.12) 0%, transparent 60%);
        z-index: 0;
        pointer-events: none;
      }
      .hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
      }
      .hero-deco {
        position: absolute;
        opacity: 0.85;
        animation: floaty 7s ease-in-out infinite;
        filter: drop-shadow(0 4px 10px rgba(20, 80, 130, 0.25));
      }
      .hero .d1 { width: 38px; top: 14%; left: 5%; animation-delay: 0s; }
      .hero .d2 { width: 32px; top: 30%; left: 38%; animation-delay: 0.6s; opacity: 0.5; }
      .hero .d3 { width: 28px; top: 82%; left: 6%; animation-delay: 1.4s; }
      .hero .d4 { width: 42px; top: 18%; left: 48%; animation-delay: 1.0s; opacity: 0.5; }
      .hero .d5 { width: 30px; top: 78%; left: 44%; animation-delay: 2.0s; opacity: 0.45; }
      .hero .d6 { width: 36px; top: 12%; right: 6%; animation-delay: 0.8s; }
      .hero .d7 { width: 48px; bottom: 14%; right: 8%; animation-delay: 2.4s; opacity: 0.55; }
      @keyframes floaty {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-12px) rotate(5deg); }
      }

      .hero-grid {
        position: relative;
        z-index: 1;
        max-width: 1280px;
        margin: 0 auto;
        width: 100%;
        display: grid;
        grid-template-columns: 1.3fr 1fr;
        gap: 24px;
        align-items: center;
      }

      .hero-text {
        max-width: 720px;
      }
      .hero-headline {
        font-weight: 900;
        font-size: clamp(30px, 3.8vw, 52px);
        line-height: 1.12;
        letter-spacing: -0.025em;
        margin-bottom: 24px;
        color: #fff;
        text-shadow: 0 2px 16px rgba(20, 80, 130, 0.25);
      }
      .hero-headline .hl-line {
        display: block;
        white-space: nowrap;
      }
      .hero-headline .hl-line.accent {
        color: #fff8c8;
        background: none;
        -webkit-text-fill-color: #fff8c8;
        padding-bottom: 0.06em;
      }
      .hero-sub {
        font-size: clamp(15px, 1.25vw, 18px);
        color: rgba(255, 255, 255, 0.94);
        line-height: 1.65;
        margin-bottom: 32px;
        text-shadow: 0 1px 8px rgba(20, 80, 130, 0.2);
      }

      /* Store CTA */
      .hero-cta {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 0;
      }
      .store-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: #1a1a1a;
        color: #fff;
        text-decoration: none;
        padding: 11px 18px;
        border-radius: 12px;
        transition: transform 0.18s, box-shadow 0.18s;
        box-shadow: 0 6px 16px rgba(0, 0, 0, 0.15);
      }
      a.store-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 22px rgba(0, 0, 0, 0.22);
      }
      .store-btn .store-icon { flex-shrink: 0; }
      .store-btn .store-text {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        line-height: 1.1;
      }
      .store-btn .store-eyebrow {
        font-size: 10px;
        font-weight: 500;
        opacity: 0.85;
        letter-spacing: 0.04em;
        margin-bottom: 2px;
      }
      .store-btn .store-name {
        font-size: 17px;
        font-weight: 600;
        letter-spacing: -0.01em;
      }
      .store-btn.coming {
        background: #3a3a3a;
        opacity: 0.55;
        cursor: not-allowed;
      }
      .store-btn.coming .store-eyebrow {
        color: var(--gold-soft);
        opacity: 1;
      }

      /* Cat stage */
      .hero-cat-stage {
        position: relative;
        width: 100%;
        max-width: 560px;
        aspect-ratio: 1;
        margin: 0 auto;
        justify-self: center;
      }
      .hero-cat-stage::before {
        content: '';
        position: absolute;
        inset: 4% 4% 6% 4%;
        background: radial-gradient(circle at 50% 50%, rgba(36, 156, 227, 0.22) 0%, rgba(36, 156, 227, 0.08) 35%, transparent 65%);
        border-radius: 50%;
        z-index: 0;
        pointer-events: none;
      }
      .cat-pedestal {
        position: absolute;
        left: 14%;
        right: 14%;
        bottom: 6%;
        height: 6%;
        background: radial-gradient(ellipse at 50% 50%, rgba(36, 80, 130, 0.22) 0%, transparent 70%);
        filter: blur(10px);
      }
      #cat-canvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        transition: opacity 0.5s;
        z-index: 2;
      }
      #cat-canvas.loaded { opacity: 1; }
      .cat-fallback {
        position: absolute;
        inset: 0;
        margin: auto;
        width: 88%;
        height: 88%;
        object-fit: contain;
        opacity: 1;
        transition: opacity 0.5s;
        z-index: 1;
        animation: catBob 4s ease-in-out infinite;
      }
      @keyframes catBob {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
      }
      #cat-canvas.loaded ~ .cat-fallback { opacity: 0; }

      @media (max-width: 980px) {
        .hero {
          height: auto;
          min-height: 0;
          padding: 28px max(20px, 5vw) 40px;
        }
        .hero-grid {
          grid-template-columns: 1fr;
          gap: 20px;
          text-align: center;
        }
        .hero-text { max-width: none; margin: 0 auto; }
        .hero-cta { justify-content: center; }
        .hero-cat-stage { justify-self: center; max-width: 280px; order: -1; }
        .hero-headline { font-size: clamp(24px, 6vw, 36px); }
        .hero-headline .hl-line { white-space: normal; }
      }
      @media (max-width: 480px) {
        .hero-cta { flex-direction: column; gap: 10px; }
        .store-btn { width: 100%; justify-content: flex-start; }
        .trust-sep { display: none; }
      }

      /* ─── Section base ─── */
      .section {
        max-width: 1100px;
        margin: 0 auto;
        padding: 100px max(20px, 6vw);
      }
      .section h2 {
        font-size: clamp(28px, 4vw, 44px);
        margin-bottom: 24px;
      }

      .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.7s, transform 0.7s;
      }
      .reveal.in {
        opacity: 1;
        transform: translateY(0);
      }

      /* ─── Pain ─── */
      .pain { text-align: center; }
      .dream-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin: 40px 0 36px;
      }
      .dream-card {
        background: #fff;
        padding: 24px 18px;
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-soft);
        font-size: 16px;
        font-weight: 700;
        color: var(--text);
        line-height: 1.5;
      }
      .pain-body {
        font-size: 17px;
        color: var(--text-soft);
        max-width: 640px;
        margin: 0 auto 20px;
        line-height: 1.8;
      }
      .pain-highlight {
        font-size: 19px;
        font-weight: 800;
        color: var(--text);
        max-width: 720px;
        margin: 0 auto;
        line-height: 1.5;
        padding: 24px 28px;
        background: linear-gradient(135deg, #fff 0%, var(--bg-soft) 100%);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-card);
      }
      @media (max-width: 720px) {
        .dream-cards { grid-template-columns: 1fr; }
      }

      /* ─── 3 Steps ─── */
      .steps { text-align: center; padding-bottom: 60px; }
      .step-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
        text-align: left;
        margin-top: 80px;
      }
      .step-row.reverse { direction: rtl; }
      .step-row.reverse > * { direction: ltr; }
      .step-text {
        max-width: 480px;
      }
      .step-tag {
        display: inline-block;
        padding: 6px 12px;
        background: var(--primary);
        color: #fff;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.1em;
        margin-bottom: 18px;
      }
      .step-text h3 {
        font-size: clamp(22px, 2.8vw, 32px);
        margin-bottom: 16px;
      }
      .step-text p {
        font-size: 16px;
        color: var(--text-soft);
        line-height: 1.7;
      }
      .step-shot {
        display: flex;
        justify-content: center;
      }
      .phone-shadow {
        position: relative;
        border-radius: 38px;
        overflow: hidden;
        box-shadow: var(--shadow-phone);
        transform: translateZ(0);
        width: 100%;
        max-width: 320px;
      }
      .phone-shadow img {
        width: 100%;
        height: auto;
        display: block;
      }
      @media (max-width: 880px) {
        .step-row, .step-row.reverse { grid-template-columns: 1fr; direction: ltr; gap: 30px; text-align: center; }
        .step-text { margin: 0 auto; }
        .step-row .step-text h3 { text-align: center; }
      }

      /* ─── Features grid ─── */
      .features { text-align: center; }
      .feature-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-top: 50px;
        text-align: left;
      }
      .feature-card {
        background: #fff;
        padding: 30px 24px;
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-soft);
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .feature-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 40px -8px rgba(36, 156, 227, 0.22);
      }
      .feature-icon {
        width: 56px;
        height: 56px;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg-soft);
        border-radius: 16px;
      }
      .feature-icon img { width: 36px; height: 36px; object-fit: contain; }
      .feature-card h3 { font-size: 18px; margin-bottom: 10px; }
      .feature-card p { font-size: 14px; color: var(--text-soft); line-height: 1.6; }
      @media (max-width: 720px) {
        .feature-grid { grid-template-columns: 1fr; }
      }

      /* ─── Diary spotlight ─── */
      .spotlight {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
      }
      .spot-text { max-width: 480px; }
      .spot-text h2 { margin-bottom: 18px; }
      .spot-text p {
        font-size: 17px;
        color: var(--text-soft);
        line-height: 1.8;
        margin-bottom: 24px;
      }
      .bullets {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .bullets li {
        display: flex;
        gap: 10px;
        font-size: 15px;
        font-weight: 600;
        color: var(--text);
      }
      .check {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 22px;
        height: 22px;
        background: var(--primary);
        color: #fff;
        border-radius: 50%;
        font-size: 12px;
        font-weight: 900;
        flex-shrink: 0;
      }
      .check.gold { background: var(--gold); }
      .spot-shot {
        display: flex;
        justify-content: center;
      }
      .spot-shot .phone-shadow { max-width: 280px; }
      @media (max-width: 880px) {
        .spotlight { grid-template-columns: 1fr; gap: 30px; text-align: center; }
        .spot-text { margin: 0 auto; }
        .bullets li { justify-content: center; }
      }

      /* ─── Companion (bg image) ─── */
      .companion {
        position: relative;
        max-width: none;
        margin: 0;
        padding: 120px max(20px, 6vw);
        overflow: hidden;
        border-radius: 0;
      }
      .companion-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        filter: brightness(0.85);
      }
      .companion-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(36, 156, 227, 0.55) 0%, rgba(122, 78, 224, 0.45) 100%);
      }
      .companion-inner {
        position: relative;
        z-index: 1;
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1.1fr 1fr;
        gap: 60px;
        align-items: center;
      }
      .companion-text { color: #fff; }
      .companion-text h2 { color: #fff; margin-bottom: 20px; }
      .companion-text p { font-size: 17px; line-height: 1.8; opacity: 0.95; margin-bottom: 24px; }
      .chip-row { display: flex; flex-wrap: wrap; gap: 8px; }
      .chip {
        padding: 8px 14px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
        color: #fff;
      }
      .companion-shot { display: flex; justify-content: center; }
      .companion-shot .phone-shadow { max-width: 280px; }
      @media (max-width: 880px) {
        .companion-inner { grid-template-columns: 1fr; gap: 30px; text-align: center; }
        .chip-row { justify-content: center; }
      }

      /* ─── iPad section ─── */
      .ipad {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
      }
      .ipad-text h2 { margin-bottom: 18px; }
      .ipad-text p { font-size: 17px; color: var(--text-soft); line-height: 1.8; }
      .ipad-shots {
        position: relative;
        height: 360px;
      }
      .ipad-frame {
        position: absolute;
        border-radius: 22px;
        overflow: hidden;
        box-shadow: var(--shadow-phone);
        background: #000;
        padding: 8px;
      }
      .ipad-frame img {
        border-radius: 14px;
        width: 100%;
        height: auto;
      }
      .ipad-frame:not(.ipad-back) {
        width: 320px;
        right: 20px;
        top: 30px;
        z-index: 2;
        transform: rotate(-3deg);
      }
      .ipad-back {
        width: 280px;
        left: 20px;
        top: 80px;
        opacity: 0.85;
        transform: rotate(4deg);
      }
      @media (max-width: 880px) {
        .ipad { grid-template-columns: 1fr; gap: 30px; text-align: center; }
        .ipad-shots { height: 280px; }
        .ipad-frame:not(.ipad-back) { right: 50%; transform: translateX(50%) rotate(-3deg); width: 260px; }
        .ipad-back { left: 50%; transform: translateX(-50%) rotate(4deg); width: 220px; }
      }

      /* ─── Pricing ─── */
      .pricing { text-align: center; padding-bottom: 60px; }
      .pricing-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        max-width: 760px;
        margin: 50px auto 0;
        text-align: left;
      }
      .price-card {
        background: #fff;
        padding: 36px 32px;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-soft);
        display: flex;
        flex-direction: column;
        gap: 24px;
        position: relative;
        border: 2px solid transparent;
      }
      .price-card.pro {
        border-color: var(--gold);
        background: linear-gradient(180deg, #fffdf6 0%, #ffffff 30%);
        box-shadow: 0 20px 60px -10px rgba(245, 177, 0, 0.25);
      }
      .pro-badge {
        position: absolute;
        top: -12px;
        right: 24px;
        padding: 6px 12px;
        background: var(--gold);
        color: #fff;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.06em;
      }
      .price-name { font-size: 14px; font-weight: 700; color: var(--text-soft); letter-spacing: 0.06em; text-transform: uppercase; }
      .price-line { display: flex; align-items: baseline; gap: 6px; margin-top: 6px; }
      .price-num { font-size: 38px; font-weight: 900; color: var(--text); }
      .price-period { font-size: 14px; color: var(--text-soft); font-weight: 600; }
      .price-note {
        display: inline-block;
        margin-top: 8px;
        font-size: 12px;
        color: var(--gold);
        font-weight: 700;
        padding: 4px 10px;
        background: rgba(245, 177, 0, 0.12);
        border-radius: 6px;
      }
      .price-items {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .price-items li {
        display: flex;
        gap: 10px;
        font-size: 14px;
        line-height: 1.5;
        color: var(--text);
      }
      .price-cta {
        display: block;
        width: 100%;
        padding: 14px;
        text-align: center;
        border-radius: var(--radius-sm);
        font-size: 15px;
        font-weight: 800;
        transition: transform 0.15s, box-shadow 0.15s;
      }
      .price-cta.primary {
        background: var(--gold);
        color: #fff !important;
      }
      .price-cta.secondary {
        background: var(--bg-soft);
        color: var(--primary) !important;
      }
      .price-cta:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 24px rgba(245, 177, 0, 0.32);
      }
      .price-cta.secondary:hover {
        box-shadow: 0 10px 24px rgba(36, 156, 227, 0.22);
      }
      .price-foot {
        font-size: 12px;
        color: var(--text-mute);
        text-align: center;
      }
      @media (max-width: 720px) {
        .pricing-grid { grid-template-columns: 1fr; }
      }

      /* ─── Languages ─── */
      .langs { text-align: center; }
      .langs-body {
        font-size: 17px;
        color: var(--text-soft);
        max-width: 600px;
        margin: 0 auto 30px;
      }
      .lang-list {
        max-width: 720px;
        margin: 0 auto;
        font-size: 16px;
        font-weight: 600;
        color: var(--text);
        line-height: 2;
        padding: 30px;
        background: linear-gradient(135deg, #fff 0%, var(--bg-soft) 100%);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-soft);
      }

      /* ─── Final CTA ─── */
      .final-cta {
        position: relative;
        max-width: none;
        margin: 0;
        text-align: center;
        background: linear-gradient(180deg, var(--bg-soft) 0%, #fff 100%);
        padding: 120px max(20px, 6vw);
        overflow: hidden;
      }
      .final-bg { position: absolute; inset: 0; pointer-events: none; }
      .final-bg .floater { animation: float 6s ease-in-out infinite; }
      .final-cta .f1 { width: 64px; top: 18%; left: 18%; }
      .final-cta .f2 { width: 48px; top: 70%; left: 22%; animation-delay: 1.2s; }
      .final-cta .f3 { width: 72px; top: 50%; right: 16%; animation-delay: 2s; opacity: 0.5; }
      .final-inner {
        position: relative;
        z-index: 1;
        max-width: 720px;
        margin: 0 auto;
      }
      .final-cat { width: 120px; margin: 0 auto 24px; }
      .final-cta h2 {
        font-size: clamp(32px, 5vw, 52px);
        margin-bottom: 18px;
      }
      .final-cta p {
        font-size: 18px;
        color: var(--text-soft);
        margin-bottom: 36px;
      }
      .hero-cta.final { justify-content: center; margin: 8px 0 0; }

      /* ─── Footer ─── */
      footer {
        background: #1b1d20;
        color: #aab1bd;
        padding: 60px max(20px, 6vw) 40px;
      }
