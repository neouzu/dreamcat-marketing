      }
      @media (max-width: 880px) {
        .ipad { grid-template-columns: 1fr; gap: 30px; text-align: center; }
        .ipad-shots { height: 280px; }
        .ipad-frame:not(.ipad-back) { right: 50%; transform: translateX(50%) rotate(-3deg); width: 260px; }
        .ipad-back { left: 50%; transform: translateX(-50%) rotate(4deg); width: 220px; }
      }

      /* ─── Pricing ─── */
      .pricing { text-align: center; padding-bottom: 60px; }
      .pricing-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        max-width: 760px;
        margin: 50px auto 0;
        text-align: left;
      }
      .price-card {
        background: #fff;
        padding: 36px 32px;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-soft);
        display: flex;
        flex-direction: column;
        gap: 24px;
        position: relative;
        border: 2px solid transparent;
      }
      .price-card.pro {
        border-color: var(--gold);
        background: linear-gradient(180deg, #fffdf6 0%, #ffffff 30%);
        box-shadow: 0 20px 60px -10px rgba(245, 177, 0, 0.25);
      }
      .pro-badge {
        position: absolute;
        top: -12px;
        right: 24px;
        padding: 6px 12px;
        background: var(--gold);
        color: #fff;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.06em;
      }
      .price-name { font-size: 14px; font-weight: 700; color: var(--text-soft); letter-spacing: 0.06em; text-transform: uppercase; }
      .price-line { display: flex; align-items: baseline; gap: 6px; margin-top: 6px; }
      .price-num { font-size: 38px; font-weight: 900; color: var(--text); }
      .price-period { font-size: 14px; color: var(--text-soft); font-weight: 600; }
      .price-note {
        display: inline-block;
        margin-top: 8px;
        font-size: 12px;
        color: var(--gold);
        font-weight: 700;
        padding: 4px 10px;
        background: rgba(245, 177, 0, 0.12);
        border-radius: 6px;
      }
      .price-items {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .price-items li {
        display: flex;
        gap: 10px;
        font-size: 14px;
        line-height: 1.5;
        color: var(--text);
      }
      .price-cta {
        display: block;
        width: 100%;
        padding: 14px;
        text-align: center;
        border-radius: var(--radius-sm);
        font-size: 15px;
        font-weight: 800;
        transition: transform 0.15s, box-shadow 0.15s;
      }
      .price-cta.primary {
        background: var(--gold);
        color: #fff !important;
      }
      .price-cta.secondary {
        background: var(--bg-soft);
        color: var(--primary) !important;
      }
      .price-cta:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 24px rgba(245, 177, 0, 0.32);
      }
      .price-cta.secondary:hover {
        box-shadow: 0 10px 24px rgba(36, 156, 227, 0.22);
      }
      .price-foot {
        font-size: 12px;
        color: var(--text-mute);
        text-align: center;
      }
      @media (max-width: 720px) {
        .pricing-grid { grid-template-columns: 1fr; }
      }

      /* ─── Languages ─── */
      .langs { text-align: center; }
      .langs-body {
        font-size: 17px;
        color: var(--text-soft);
        max-width: 600px;
        margin: 0 auto 30px;
      }
      .lang-list {
        max-width: 720px;
        margin: 0 auto;
        font-size: 16px;
        font-weight: 600;
        color: var(--text);
        line-height: 2;
        padding: 30px;
        background: linear-gradient(135deg, #fff 0%, var(--bg-soft) 100%);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-soft);
      }

      /* ─── Final CTA ─── */
      .final-cta {
        position: relative;
        max-width: none;
        margin: 0;
        text-align: center;
        background: linear-gradient(180deg, var(--bg-soft) 0%, #fff 100%);
        padding: 120px max(20px, 6vw);
        overflow: hidden;
      }
      .final-bg { position: absolute; inset: 0; pointer-events: none; }
      .final-bg .floater { animation: float 6s ease-in-out infinite; }
      .final-cta .f1 { width: 64px; top: 18%; left: 18%; }
      .final-cta .f2 { width: 48px; top: 70%; left: 22%; animation-delay: 1.2s; }
      .final-cta .f3 { width: 72px; top: 50%; right: 16%; animation-delay: 2s; opacity: 0.5; }
      .final-inner {
        position: relative;
        z-index: 1;
        max-width: 720px;
        margin: 0 auto;
      }
      .final-cat { width: 120px; margin: 0 auto 24px; }
      .final-cta h2 {
        font-size: clamp(32px, 5vw, 52px);
        margin-bottom: 18px;
      }
      .final-cta p {
        font-size: 18px;
        color: var(--text-soft);
        margin-bottom: 36px;
      }
      .appstore-badge.big {
        display: inline-block;
        border-radius: 12px;
      }

      /* ─── Footer ─── */
      footer {
        background: #1b1d20;
        color: #aab1bd;
        padding: 60px max(20px, 6vw) 40px;
      }
      .footer-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1.4fr 1fr 1fr;
        gap: 40px;
        align-items: start;
      }
      .footer-brand {
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .footer-brand img { width: 44px; height: 44px; border-radius: 10px; }
      .footer-brand strong { display: block; color: #fff; font-size: 18px; }
      .footer-tag { font-size: 13px; opacity: 0.7; }
      .footer-nav {
        display: flex;
        flex-direction: column;
        gap: 10px;
        font-size: 14px;
      }
      .footer-nav a {
        color: #aab1bd;
        transition: color 0.15s;
      }
      .footer-nav a:hover { color: #fff; }
      .footer-copy {
        font-size: 12px;
        opacity: 0.6;
        text-align: right;
      }
      @media (max-width: 720px) {
        .footer-inner { grid-template-columns: 1fr; }
        .footer-copy { text-align: left; }
      }
    </style>
  </body>
</html>
